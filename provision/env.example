# GitHub token (needs repo, issues, checks permissions).
# Must be a fine-grained PAT (github_pat_…) or classic PAT (ghp_…).
# Do NOT use an OAuth app token (gho_…): the worker's ProtectHome=read-only
# systemd sandbox prevents gh from refreshing it, causing auth failures.
GITHUB_TOKEN=ghp_your_token_here
GH_TOKEN=ghp_your_token_here

# Claude Code auth (pick ONE):
# Option 1: OAuth token from `claude setup-token` (recommended for headless)
CLAUDE_CODE_OAUTH_TOKEN=your_setup_token_here
# Option 2: Anthropic API key (pay-per-token via Console)
# ANTHROPIC_API_KEY=sk-ant-your_key_here
